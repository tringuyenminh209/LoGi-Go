# ─────────────────────────────────────────────
# Logi-Go — Environment Variables
# Copy to .env and fill in values
# ─────────────────────────────────────────────

# Environment
ENV=development

# PostgreSQL
POSTGRES_DB=logigo
POSTGRES_USER=logigo
POSTGRES_PASSWORD=logigo
PG_DSN=postgres://logigo:logigo@localhost:5432/logigo?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379

# JWT (dev: generate with `make gen-keys`)
JWT_PRIVATE_KEY_PATH=./secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt_public.pem

# MinIO (dev object storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=logi-go-images

# LLM APIs (leave empty to use mock in dev)
GEMINI_API_KEY=
OPENAI_API_KEY=
USE_MOCK_LLM=true

# Firebase (leave empty to use emulator in dev)
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=
USE_FCM_EMULATOR=true

# JMA EEW (dev: mock server)
JMA_WS_URL=ws://localhost:9999
USE_JMA_MOCK=true

# IOWN APN (production only)
IOWN_API_URL=
IOWN_API_KEY=

# External Integrations (dev: mock)
HACOBELL_BASE_URL=http://localhost:4010
HACOBELL_CLIENT_ID=
HACOBELL_CLIENT_SECRET=

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=debug

# CORS (dev)
CORS_ORIGINS=http://localhost:5173
